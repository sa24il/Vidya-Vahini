<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app_res="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Top Blue Section -->
    <View
        android:id="@+id/topBackground"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/primary"
        app_res:layout_constraintHeight_percent="0.35"
        app_res:layout_constraintTop_toTopOf="parent" />

    <!-- Logo & Steps -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="32dp"
        app_res:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            app_res:cardBackgroundColor="@color/accent"
            app_res:cardCornerRadius="12dp"
            app_res:cardElevation="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@drawable/ic_bus"
                app_res:tint="@color/white" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="sans-serif-black"
            android:text="Vidya-Vahini"
            android:textColor="@color/white"
            android:textSize="20sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.7"
            android:text="Your Student Commute Buddy"
            android:textColor="@color/white"
            android:textSize="12sp" />

        <!-- Step Indicator -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/step1Indicator"
                android:layout_width="24dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_orange" />

            <View
                android:id="@+id/step2Indicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/circle_grey" />

            <View
                android:id="@+id/step3Indicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/circle_grey" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvStepCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Step 1 of 3"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Main Card Content -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app_res:cardCornerRadius="32dp"
        app_res:cardElevation="8dp"
        app_res:layout_constraintBottom_toBottomOf="parent"
        app_res:layout_constraintTop_toBottomOf="@+id/headerLayout"
        android:layout_marginTop="24dp"
        android:translationY="24dp">

        <ViewFlipper
            android:id="@+id/onboardingFlipper"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingBottom="48dp">

            <!-- Step 1: Profile Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Let's get you set up"
                    android:textColor="@color/primary"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tell us about your daily commute"
                    android:textColor="@android:color/darker_gray" />

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_input_field"
                    android:drawableStart="@drawable/ic_user"
                    android:drawablePadding="16dp"
                    android:hint="Full Name"
                    android:padding="16dp" />
                <EditText
                    android:id="@+id/etMobile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_field"
                    android:drawableStart="@drawable/ic_phone"
                    android:drawablePadding="16dp"
                    android:hint="Your Mobile Number (10 digits)"
                    android:inputType="phone"
                    android:maxLength="10"
                    android:padding="16dp" />

                <EditText
                    android:id="@+id/etPin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_field"
                    android:drawableStart="@drawable/ic_lock"
                    android:drawablePadding="16dp"
                    android:hint="Create 4-digit PIN"
                    android:inputType="numberPassword"
                    android:maxLength="4"
                    android:padding="16dp" />
                
                <Spinner
                    android:id="@+id/spinnerCollege"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="8dp" />

                <Spinner
                    android:id="@+id/spinnerRoute"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="8dp" />

                <EditText
                    android:id="@+id/etParentPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_input_field"
                    android:drawableStart="@drawable/ic_phone"
                    android:drawablePadding="16dp"
                    android:hint="Parent Mobile Number"
                    android:inputType="phone"
                    android:padding="16dp" />

                <Button
                    android:id="@+id/btnStep1Next"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="32dp"
                    android:text="Get Started →"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    app_res:cornerRadius="12dp"
                    android:backgroundTint="@color/accent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="24dp"
                    android:alpha="0.5"
                    android:text="Your data stays on your device"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Step 2: Permissions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="Stay in the Loop"
                    android:textColor="@color/primary"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="We'll ping you when your bus is near"
                    android:textColor="@android:color/darker_gray" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_bell" app_res:tint="@color/primary"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Bus arrival alerts" android:textColor="@color/primary" android:textStyle="bold"/>
                    <Switch android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_warning" app_res:tint="@color/primary"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Delay &amp; breakdown alerts" android:textColor="@color/primary" android:textStyle="bold"/>
                    <Switch android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_check" app_res:tint="@color/primary"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:text="Safe arrival confirmation" android:textColor="@color/primary" android:textStyle="bold"/>
                    <Switch android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnStep2Next"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="48dp"
                    android:text="Enable &amp; Continue →"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    app_res:cornerRadius="12dp"
                    android:backgroundTint="@color/accent" />

                <TextView
                    android:id="@+id/tvSkipStep2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:text="Skip for now"
                    android:textColor="@android:color/darker_gray"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Step 3: Confirmation -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="32dp">

                <ImageView
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_marginTop="24dp"
                    android:src="@drawable/ic_success_check" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="sans-serif-black"
                    android:text="You're all set! 🎉"
                    android:textColor="@color/primary"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/tvSelectedRoute"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Tracking Route VV-07"
                    android:textColor="@color/accent"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Parent notified • Alerts enabled"
                    android:textColor="@android:color/darker_gray" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    app_res:cardBackgroundColor="@color/background"
                    app_res:cardCornerRadius="16dp"
                    app_res:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView android:id="@+id/tvSummaryCollege" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="College: Govt Science College" android:textColor="@color/primary" android:textSize="14sp"/>
                        <TextView android:id="@+id/tvSummaryPhone" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Parent: +91 9876543210" android:textColor="@color/primary" android:textSize="14sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <Button
                    android:id="@+id/btnFinishOnboarding"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="40dp"
                    android:text="Start Tracking →"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    app_res:cornerRadius="12dp"
                    android:backgroundTint="@color/accent" />

            </LinearLayout>

        </ViewFlipper>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
